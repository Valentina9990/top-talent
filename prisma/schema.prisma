generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  image         String?
  password      String?
  email         String    @unique
  role          UserRole  @default(PLAYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?

  // NextAuth.js relations
  accounts Account[]

  // Player profile
  playerProfile PlayerProfile?

  // School profile
  schoolProfile SchoolProfile?

  // Scout profile
  scoutProfile ScoutProfile?
}

enum UserRole {
  ADMIN
  PLAYER
  SCHOOL
  SCOUT
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
}

model Position {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "Delantero", "Mediocampista", "Defensa", "Portero"
  createdAt DateTime @default(now())

  players    PlayerProfile[] @relation("PlayerPositions")
  primaryFor PlayerProfile[] @relation("PrimaryPosition")

  @@map("positions")
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())

  cities         City[]
  playerProfiles PlayerProfile[]

  schoolProfiles SchoolProfile[]

  scoutProfiles  ScoutProfile[]

  @@map("departments")
}

model City {
  id           String     @id @default(cuid())
  name         String
  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())

  playerProfiles PlayerProfile[]

  schoolProfiles SchoolProfile[]

  scoutProfiles  ScoutProfile[]

  @@unique([name, departmentId])
  @@map("cities")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "Sub-17", "Sub-20", "Senior"
  minAge    Int?
  maxAge    Int?
  createdAt DateTime @default(now())

  players PlayerProfile[]
  schools SchoolProfile[] @relation("SchoolCategories")

  @@map("categories")
}

model PlayerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  team          String?
  schoolId      String?  @map("school_id")
  school        SchoolProfile? @relation(fields: [schoolId], references: [id])
  schoolVerified Boolean @default(false)
  zone          String?
  bio           String? @db.Text
  preferredFoot String? // "RIGHT", "LEFT", "BOTH"

  // Position and Category - Many-to-Many for positions
  positions         Position[] @relation("PlayerPositions")
  primaryPositionId String?    @map("primary_position_id")
  primaryPosition   Position?  @relation("PrimaryPosition", fields: [primaryPositionId], references: [id])

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  // Location
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])
  cityId       String?     @map("city_id")
  city         City?       @relation(fields: [cityId], references: [id])

  // Stats
  goals         Int @default(0)
  assists       Int @default(0)
  matchesPlayed Int @default(0)

  // Media
  profileVideoUrl String?
  fullVideoUrl    String?
  videos          PlayerVideo[]

  // Achievements
  achievements PlayerAchievement[]

  // Scout relations
  contactedByScouts ScoutContactedPlayer[]
  favoritedByScouts ScoutFavoritePlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("player_profiles")
}

model PlayerVideo {
  id       String        @id @default(cuid())
  playerId String        @map("player_id")
  player   PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  videoUrl    String
  title       String?
  description String?  @db.Text
  createdAt   DateTime @default(now())

  @@map("player_videos")
}

model PlayerAchievement {
  id       String        @id @default(cuid())
  playerId String        @map("player_id")
  player   PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  title       String
  description String?   @db.Text
  date        DateTime?
  verified    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("player_achievements")
}

model SchoolProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  officialName String? // Nombre oficial de la escuela
  nit          String? // NIT (opcional)
  description  String? @db.Text
  mission      String? @db.Text
  vision       String? @db.Text

  // Location
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])
  cityId       String?     @map("city_id")
  city         City?       @relation(fields: [cityId], references: [id])
  address      String? // Dirección específica

  // Contact
  phone        String?
  contactEmail String?
  facebookUrl  String?
  instagramUrl String?
  websiteUrl   String?

  // Sports Data
  categories         Category[] @relation("SchoolCategories")
  players            PlayerProfile[]
  approximatePlayers Int? // Número aproximado de jugadores
  headCoachName      String? // Nombre del director técnico principal
  achievements       String?    @db.Text // Logros destacados (texto libre)
  posts SchoolPost[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("school_profiles")
}

model SchoolPost {
  id            String        @id @default(cuid())
  schoolId      String        @map("school_id")
  school        SchoolProfile @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  title         String
  description   String        @db.Text
  mediaUrl      String?       
  mediaType     String?       
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("school_posts")
  @@index([schoolId])
  @@index([createdAt])
}

model ScoutProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  fullName        String?
  primaryPhone    String?
  secondaryPhone  String?

  // Location (using Department and City tables)
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])
  cityId       String?     @map("city_id")
  city         City?       @relation(fields: [cityId], references: [id])

  // Experience
  yearsExperience Int?

  // Player relations
  contactedPlayers ScoutContactedPlayer[]
  favoritePlayers  ScoutFavoritePlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scout_profiles")
}

model ScoutContactedPlayer {
  id       String        @id @default(cuid())
  scoutId  String        @map("scout_id")
  scout    ScoutProfile  @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  playerId String        @map("player_id")
  player   PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([scoutId, playerId])
  @@map("scout_contacted_players")
}

model ScoutFavoritePlayer {
  id       String        @id @default(cuid())
  scoutId  String        @map("scout_id")
  scout    ScoutProfile  @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  playerId String        @map("player_id")
  player   PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([scoutId, playerId])
  @@map("scout_favorite_players")
}

